# ORBS Runner → Supabase Auth (email + username / account modal)
#
# 1. Dashboard: https://supabase.com/dashboard/project/_/settings/general
# 2. Authentication → Providers → Email → ON (optional: disable "Confirm email" for local dev)
# 3. Project Settings → API → copy Project URL and anon public key (not service_role)
#
# Shop (coins/skins) stays in the browser only — not in Supabase.
#
# Copy to `.env.local`, paste real values, save, then restart Vite or the dev server.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Plain static serve (no Vite): set before the app loads:
#   window.__NR_SUPABASE__ = { url: "https://....supabase.co", anonKey: "eyJ..." };
